rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Prayers Collection Rules
    match /prayers/{prayerId} {
      // Anyone can submit a prayer request (Public form)
      allow create: if isValidId(prayerId) && isValidPrayerOnCreate(request.resource.data);
      
      // Reading is allowed so the Admin/family can view the lists
      allow read: if true;
      
      // Only "isRead" and "updatedAt" can be updated, modifying status
      allow update: if isValidId(prayerId) 
        && isValidPrayerOnUpdate(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'updatedAt']);
        
      // No deletion allowed by default to prevent loss of prayers
      allow delete: if false;
    }

    // --- Helper Functions ---
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidPrayerOnCreate(data) {
      return data.keys().hasAll(['senderName', 'prayerText', 'isRead', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5
        && data.senderName is string
        && data.senderName.size() >= 1
        && data.senderName.size() <= 200
        && data.prayerText is string
        && data.prayerText.size() >= 5
        && data.prayerText.size() <= 10000
        && data.isRead == false
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // Validation for update: senderName and prayerText must remain unchanged (checked via hasOnly on keys)
    function isValidPrayerOnUpdate(data) {
      return data.senderName is string
        && data.senderName.size() >= 1
        && data.senderName.size() <= 200
        && data.prayerText is string
        && data.prayerText.size() >= 5
        && data.prayerText.size() <= 10000
        && data.isRead is bool
        && data.updatedAt == request.time;
    }
  }
}
